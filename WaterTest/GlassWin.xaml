<Window x:Class="WaterTest.GlassWin"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WaterTest"
        mc:Ignorable="d"
        Title="GlassWin" WindowStartupLocation="CenterScreen" MouseLeftButtonDown="WinHead_MouseLeftButtonDown" Height="450" Width="800" Background="Transparent" AllowsTransparency="True" WindowStyle="None"  Loaded="Window_Loaded">
    <Grid>
        <Button Content="✕"
        Width="28"
        Height="28"
        HorizontalAlignment="Right"
        VerticalAlignment="Top"
        Margin="0,10,10,0"
        Panel.ZIndex="10"
        FontSize="14"
        Foreground="White"
        Background="#22FFFFFF"
        BorderBrush="#33FFFFFF"
        Cursor="Hand"
        Click="Close_Click">

            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="6">

                        <ContentPresenter HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Button.Template>

            <Button.Effect>
                <DropShadowEffect Color="#000000"
                          BlurRadius="10"
                          ShadowDepth="2"
                          Opacity="0.3"/>
            </Button.Effect>
        </Button>
        
        <Border Margin="5" Name="Root" BorderThickness="1" CornerRadius="9" Panel.ZIndex="1">
            <Border.Effect>
                <BlurEffect Radius="1" KernelType="Gaussian"/>
            </Border.Effect>
        </Border>
        <Border BorderThickness="1" CornerRadius="9" Panel.ZIndex="3" Background="#FFCADEF7" Opacity="0.05" >
           
        </Border>

        <Label VerticalAlignment="Center"
       HorizontalAlignment="Center"
       FontSize="30"
       FontWeight="Bold"
       Foreground="White"
       Panel.ZIndex="5">

            <Label.Effect>
                <DropShadowEffect Color="#00FFFF"
                          BlurRadius="25"
                          ShadowDepth="0"
                          Opacity="0.9"/>
            </Label.Effect>

            Water Glass
        </Label>
    </Grid>
</Window>
